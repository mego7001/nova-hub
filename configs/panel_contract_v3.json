    {
      "action_id": "voice_stop",
      "source_panel": "voice",
      "requires_approval": false,
      "fallback_behavior": "show_status",
      "telemetry_key": "action.voice.stop"
    },
    {
      "action_id": "voice_replay",
      "source_panel": "voice",
      "requires_approval": false,
      "fallback_behavior": "show_status",
      "telemetry_key": "action.voice.replay"

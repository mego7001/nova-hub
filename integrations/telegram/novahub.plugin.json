{
  "id": "telegram",
  "name": "Telegram Bot API",
  "version": "1.0.0",
  "kind": "integration",
  "entrypoint": "integrations.telegram.plugin",
  "tool_groups": [
    "telegram",
    "network"
  ],
  "config_schema": {
    "type": "object",
    "properties": {
      "bot_token": {
        "type": "string"
      },
      "default_chat_id": {
        "type": "string"
      },
      "timeout_sec": {
        "type": "integer"
      }
    },
    "required": []
  }
}